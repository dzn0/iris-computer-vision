# NuGet packages (restored automatically via nuget restore)
packages/
*.nupkg

# Backup and temp
Backup/
Temp/
*.bak
*.tmp

# Models and big binary resources — too large for git, supply manually
*.onnx

# Resource binaries — supplied manually on each machine
# (DLLs are too large for git; Driver.sys/mapper.exe must not be public)
IrisCore/rsc/*.dll
IrisCore/rsc/Driver.sys
IrisCore/rsc/mapper.exe
Driver/rsc/
Loader/

